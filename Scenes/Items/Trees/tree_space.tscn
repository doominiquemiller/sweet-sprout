[sub_resource type="GDScript" id="GDScript_3ro8n"]
script/source = "extends Area2D

# =============================================================
#  TreeSpace Area — Parcela de cultivo modular (Teclado sin Mouse)
# =============================================================

# Buscamos de forma segura el nodo PlantingSystem en la escena actual
@onready var planting_system = get_tree().current_scene.get_node_or_null(\"PlantingSystem\")

var is_player_inside : bool = false
var hosted_tree     : Node = null

# Mapeo de semillas a tipos de frutas
const SEED_TO_FRUIT : Dictionary = {
	\"apple_seed\":  \"apple\",
	\"pear_seed\":   \"pear\",
	\"orange_seed\": \"orange\",
	\"peach_seed\":  \"peach\",
}

func _ready() -> void:
	if not body_entered.is_connected(_on_body_entered):
		body_entered.connect(_on_body_entered)
	if not body_exited.is_connected(_on_body_exited):
		body_exited.connect(_on_body_exited)

## Funciones de estado para el control del PlantingSystem
func is_empty() -> bool:
	return hosted_tree == null

func set_occupied(tree_node: Node) -> void:
	hosted_tree = tree_node
	# Si el árbol es removido o cosechado en el futuro, liberamos la parcela automáticamente
	if is_instance_valid(hosted_tree):
		hosted_tree.tree_exiting.connect(func():
			hosted_tree = null
			print(\"[TreeSpace] Parcela de tierra liberada.\")
		)

func _unhandled_input(event: InputEvent) -> void:
	if not is_player_inside:
		return

	if event.is_action_pressed(\"interact\") or (event is InputEventKey and event.pressed and event.keycode == KEY_F):
		_try_plant()

func _try_plant() -> void:
	if not is_empty():
		print(\"[TreeSpace] Parcela ocupada.\")
		return

	var selected_seed : String = Inventory.get_item_seleccionado()
	if selected_seed == \"\" or not SEED_TO_FRUIT.has(selected_seed):
		print(\"[TreeSpace] Selecciona una semilla válida en tu inventario.\")
		return

	if not Inventory.has_item(selected_seed, 1):
		print(\"[TreeSpace] No te quedan unidades de esta semilla.\")
		Inventory.limpiar_seleccion()
		return

	# Si pasa los filtros, procesamos el consumo de la semilla e invocamos al gestor central
	_plant_tree(selected_seed)

func _plant_tree(seed_id: String) -> void:
	if not planting_system:
		print(\"⚠️ [TreeSpace] ERROR: No se encontró 'PlantingSystem' en la escena raíz.\")
		return

	# Descontamos el ítem de forma definitiva del inventario global
	Inventory.remove_item(seed_id, 1)

	# Extraemos el string de la fruta (ej: \"apple\")
	var fruit_type : String = SEED_TO_FRUIT[seed_id]
	
	# CORREGIDO: Le delegamos la instanciación al PlantingSystem pasándole esta parcela y la fruta real
	planting_system.plant_tree_at_space(self, fruit_type)

	# Limpiamos el slot visual de la mano si nos quedamos sin unidades
	if not Inventory.has_item(seed_id, 1):
		Inventory.limpiar_seleccion()

# =============================================================
#  DETECCIÓN DEL CUERPO (PLAYER)
# =============================================================
func _on_body_entered(body: Node2D) -> void:
	if body.is_in_group(\"player\") or body.name == \"Player\":
		is_player_inside = true

func _on_body_exited(body: Node2D) -> void:
	if body.is_in_group(\"player\") or body.name == \"Player\":
		is_player_inside = false
"

