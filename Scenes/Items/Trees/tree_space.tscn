[sub_resource type="GDScript" id="GDScript_3ro8n"]
script/source = "extends Area2D

# =============================================================
#  TreeSpace Area — Parcela Autónoma (Tiempo Real Corregida)
# =============================================================

@export var fruit_tree_scene : PackedScene = preload(\"res://Scenes/Items/Trees/fruit_trees.tscn\")

var is_player_inside : bool = false
var hosted_tree     : Node = null

const SEED_TO_FRUIT : Dictionary = {
	\"apple_seed\":   \"apple\",
	\"pear_seed\":    \"pear\",
	\"orange_seed\":  \"orange\",
	\"peach_seed\":   \"peach\",
}

func _ready() -> void:
	add_to_group(\"tree_space\")
	
	if body_entered.is_connected(_on_body_entered):
		body_entered.disconnect(_on_body_entered)
	if body_exited.is_connected(_on_body_exited):
		body_exited.disconnect(_on_body_exited)
		
	body_entered.connect(_on_body_entered)
	body_exited.connect(_on_body_exited)

func _unhandled_input(event: InputEvent) -> void:
	if not is_player_inside:
		return

	if event.is_action_pressed(\"interact\") or (event is InputEventKey and event.pressed and event.keycode == KEY_F):
		_handle_space_interaction()

func _handle_space_interaction() -> void:
	# 1. SI YA HAY UN ÁRBOL INSTANCIADO: Intentamos interactuar con él
	if hosted_tree != null and is_instance_valid(hosted_tree):
		if hosted_tree.get(\"is_ready\") == true:
			if hosted_tree.has_method(\"collect_harvest\"):
				hosted_tree.collect_harvest() # Usamos el método unificado
			elif hosted_tree.has_method(\"_harvest\"):
				hosted_tree._harvest() # Fallback por si acaso
		else:
			print(\"[TreeSpace] El árbol está creciendo o no tiene frutas listas aún.\")
		
		return # CORREGIDO: Bloquea aquí siempre para evitar que intente plantar encima

	# 2. SI NO HAY ÁRBOL: Procedemos al proceso de plantado
	_try_plant()

func _try_plant() -> void:
	var selected_seed : String = Inventory.get_item_seleccionado()
	if selected_seed == \"\" or not SEED_TO_FRUIT.has(selected_seed):
		print(\"[TreeSpace] Selecciona una semilla de árbol válida en tu inventario.\")
		return

	if not Inventory.has_item(selected_seed, 1):
		print(\"[TreeSpace] No te quedan unidades de esta semilla.\")
		Inventory.limpiar_seleccion()
		return

	_plant_tree_directly(selected_seed)

func _plant_tree_directly(seed_id: String) -> void:
	if not fruit_tree_scene:
		print(\"⚠️ [TreeSpace] ERROR: Falta asignar la escena de los árboles.\")
		return

	Inventory.remove_item(seed_id, 1)
	var fruit_type : String = SEED_TO_FRUIT[seed_id]

	var new_tree = fruit_tree_scene.instantiate()
	add_child(new_tree)
	
	new_tree.position = Vector2.ZERO
	new_tree.z_index = 1

	if new_tree.has_method(\"plant\"):
		new_tree.plant(fruit_type)

	hosted_tree = new_tree
	
	new_tree.tree_exiting.connect(func():
		hosted_tree = null
		print(\"[TreeSpace] Parcela liberada.\")
	)

	if not Inventory.has_item(seed_id, 1):
		Inventory.limpiar_seleccion()
		
	print(\"[TreeSpace] ¡Árbol de %s plantado y centrado correctamente!\" % fruit_type)

# =============================================================
#  DETECCIÓN JUGADOR
# =============================================================
func _on_body_entered(body: Node2D) -> void:
	if body.is_in_group(\"player\") or body.name == \"Player\":
		is_player_inside = true

func _on_body_exited(body: Node2D) -> void:
	if body.is_in_group(\"player\") or body.name == \"Player\":
		is_player_inside = false
"

